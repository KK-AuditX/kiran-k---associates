# ─── Sanity CMS ────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_TOKEN=your_sanity_token          # write token for mutations

# ─── Email (Nodemailer / Zoho SMTP) ────────────────────────────
EMAIL_USER=kiran@kka.co.in
EMAIL_PASSWORD=your_email_password
SMTP_HOST=smtp.zoho.in
SMTP_PORT=587
SMTP_SECURE=false

# ─── NextAuth ──────────────────────────────────────────────────
NEXTAUTH_SECRET=your_random_32_char_secret   # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# ─── Admin credentials (stored in env, no DB needed) ───────────
ADMIN_EMAIL=admin@kka.co.in
ADMIN_PASSWORD=your_strong_password
